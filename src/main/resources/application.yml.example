server:
  port: 8080

spring:
  application:
    name: cgad-platform
  servlet:
    multipart:
      max-file-size: 20MB
      max-request-size: 20MB


langchain4j:
  provider: dashscope
  dashscope:
    api-key: ${DASHSCOPE_API_KEY:your-dashscope-api-key-here}
    model-name: qwen-plus
    temperature: 0.1
    max-tokens: 4096
  deepseek:
    api-key: ${DEEPSEEK_API_KEY:your-deepseek-api-key-here}
    model-name: deepseek-chat
    base-url: ${DEEPSEEK_BASE_URL:https://api.deepseek.com/v1}
    temperature: 0.1
    max-tokens: 4096

app:
  upload:
    dir: ${java.io.tmpdir}/cgad-uploads
  export:
    dir: ${java.io.tmpdir}/cgad-exports
